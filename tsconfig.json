{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "outDir": "./out",
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": false,
    "types": ["node", "vscode"]
  },
  "include": [
    "src/**/*",
    "vendor/vscode-dts/vscode.proposed.languageModelThinkingPart.d.ts",
    "vendor/vscode-dts/vscode.proposed.chatProvider.d.ts"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
